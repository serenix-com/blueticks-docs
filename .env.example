# Comma-separated list of API server URLs the playground exposes.
# When the list has one entry, the Server URL pill becomes a static label
# (the dropdown dialog is suppressed).
#
# Set per-context in Netlify (see netlify.toml):
#   - production         → "https://api.blueticks.co"
#   - staging / preview  → "https://api.blueticks.co,https://stg-api.blueticks.co"
#
# Local dev: leave unset to default to both.
# NEXT_PUBLIC_API_SERVERS=https://api.blueticks.co,https://stg-api.blueticks.co
